# 系统环境配置模板
# 复制为.env文件并修改为实际配置

# 服务配置
SERVICE_NAME=quant-trading-system
ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0
SECRET_KEY=your-secret-key-here-keep-it-safe

# JWT配置
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quant

# ClickHouse配置
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=quant

# InfluxDB配置
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=quant
INFLUXDB_BUCKET=realtime

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=quant-group

# 数据源API Key
TUSHARE_API_KEY=your-tushare-api-key
WIND_API_KEY=your-wind-api-key
JOINQUANT_API_KEY=your-joinquant-api-key

# 数据源优先级配置（数字越小优先级越高）
# AKShare 默认最高优先级，无需API Key，开源免费
AKSHARE_PRIORITY=1
TUSHARE_PRIORITY=5
WIND_PRIORITY=10
JOINQUANT_PRIORITY=15

# 数据源权重配置（用于加权随机选择）
AKSHARE_WEIGHT=2.0
TUSHARE_WEIGHT=1.5
WIND_WEIGHT=1.0
JOINQUANT_WEIGHT=1.0

# Jaeger链路追踪
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1

# 告警配置
WECHAT_WEBHOOK=your-wechat-webhook-url
SMS_API_KEY=your-sms-api-key
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=./logs

# 数据自动同步任务配置
# Cron表达式格式: 分 时 日 月 周
# 日线同步默认每天收盘后 16:00 执行
DAILY_SYNC_CRON=0 16 * * *
# 分钟线同步默认每天 17:00 执行
MINUTE_SYNC_CRON=0 17 * * *
# Tick同步默认每天 18:00 执行
TICK_SYNC_CRON=0 18 * * *

# 是否启用各频率同步
ENABLE_DAILY_SYNC=true
ENABLE_MINUTE_SYNC=false
ENABLE_TICK_SYNC=false

# 同步参数
SYNC_BATCH_SIZE=10
SYNC_MAX_RETRIES=3
SYNC_DEFAULT_START_DATE=2020-01-01

# 股票过滤
FILTER_ONLY_LISTED=true
FILTER_EXCLUDE_ST=true
